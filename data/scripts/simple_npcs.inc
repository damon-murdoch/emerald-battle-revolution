BattleFrontier_Underground_B1F_EventScript_LegendaryShop_Visitor1_Text_1:
# 93 "data/scripts/simple_npcs.pory"
	.string "You can buy new training-ready\l"
	.string "POKéMON, or even breed your own!$"

BattleFrontier_Underground_B1F_EventScript_LegendaryShop_Visitor1_Text_2:
# 94 "data/scripts/simple_npcs.pory"
